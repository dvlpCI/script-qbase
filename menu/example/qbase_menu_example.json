{
    "custom": [
        {
            "type": "command",
            "des": "自定义命令的操作",
            "values": [
                {
                    "des": "增加自定义的命令",
                    "key": "add custom command",
                    "command": "open $QBASE_CUSTOM_MENU"
                }
            ]
        },
        {
            "type": "test",
            "des": "测试执行命令的三种方式",
            "values": [
                {
                    "key": "测试执行命令的第一种方式[command]",
                    "des": "打开上传包的网站(pgyer)",
                    "command": "open https://www.pgyer.com/"
                },
                {
                    "key": "测试执行命令的第二种方式[commandScriptPathGetter]",
                    "des": "获取给app的版本号和build号",
                    "commandScriptPathGetter": "qbase -path getAppVersionAndBuildNumber",
                    "commandScriptArgs": ""
                },
                {
                    "key": "测试执行命令的第三种方式[execSourcePathGetter]",
                    "des": "打印结果到控制台",
                    "execSourcePathGetter": "qbase -path function_log_msg",
                    "execSourceFunAndArgs": "logResultValueToConsole \"helloworld\""
                }
            ]
        },
        {
            "type": "daily_use",
            "des": "日常使用的操作",
            "values": [
                {
                    "des": "新建 dvlproadHexo 页面(\"execMode\": \"edit\")",
                    "key": "新建 dvlproadHexo 页面",
                    "command": "cd /Users/qian/Project/dvlproadHexo && hexo new post --path AI/AIGC/反推 \"反推\"",
                    "execMode": "edit",
                    "quitAfterExec": true
                },
                {
                    "des": "修改 cc-connect 的项目(quitAfterExec)",
                    "key": "修改 cc-connect 的项目",
                    "command": "open ~/.cc-connect/config.toml",
                    "quitAfterExec": true
                },
                {
                    "des": "打开 open design 及其使用手册(自动开终端并激活窗口到最前 使用 osascript -e )",
                    "key": "打开 open design 及其使用手册",
                    "command": "open https://dvlproad.github.io/AI/AI-%E2%91%A1Open%20Design/ && osascript -e 'tell application \"Terminal\" to do script \"cd ~/Project/AI/open-design && pnpm tools-dev run web\"' -e 'tell application \"Terminal\" to activate'"
                },
                {
                    "des": "打开 ComfyUI(自动开终端并激活窗口到最前 使用 \"execMode\": \"inNewTabEdit\")",
                    "key": "打开 ComfyUI",
                    "command": "source ~/Project/AI/comfy_env/bin/activate && cd ~/Project/ComfyUI && python3.12 main.py --enable-manager",
                    "execMode": "inNewTabEdit"
                }
            ]
        },
        {
            "type": "normal",
            "des": "自定义要执行的普通脚本",
            "values": [
                {
                    "des": "输出当前目录下的文件",
                    "key": "ls",
                    "command": "ls"
                },
                {
                    "des": "查看 pod 的版本",
                    "key": "pod --version",
                    "command": "pod --version"
                },
                {
                    "des": "查看 ~/.ssh 文件夹",
                    "key": "open ~/.ssh",
                    "command": "open ~/.ssh"
                },
                {
                    "des": "查看 homebrew 的 Taps 文件夹",
                    "key": "open /opt/homebrew/Library",
                    "command": "open /opt/homebrew/Library"
                },
                {
                    "des": "查看 Project 文件",
                    "key": "goProject",
                    "command": "open ~/Project/"
                },
                {
                    "des": "查看 pp 文件(路径有空格，所以将整个路径包在\"\"中)",
                    "key": "go Provisioning Profiles",
                    "command": "open \"~/Library/Developer/Xcode/UserData/Provisioning Profiles/\""
                },
                {
                    "des": "查看压缩包结构，避免使用系统解压工具导致被默认解压到与压缩包同名的文件夹内，而导致看不到原本内容是对文件夹内的进行压缩，还是对文件夹进行压缩",
                    "key": "unzip -q xxx.zip 或 unar -e GBK xxx.zip(需先 brew install unar 安装)",
                    "command": "echo \"unzip -q /path/to/your/yourfilename.zip\" 或 \"unar -e GBK /path/to/your/yourfilename.zip(需先 brew install unar 安装)\""
                }
            ]
        },
        {
            "type": "git",
            "des": "git命令",
            "values": [
                {
                    "des": "大概命令： ② git checkout -b test/ad  ④ git push -u origin test/ad",
                    "key": "查看完整的如何本地git提交的命令",
                    "command": "echo \"①查看远程是否已有要关联的本地分支 git branch -r \\n②创建本地分支 git checkout -b test/ad \\n③添加并提交更改：git add . && git commit -m \"Initial commit for test/ad\" \\n④推送到远程分支 git push -u origin test/ad \""
                }
            ]
        },
        {
            "type": "usual",
            "des": "自定义要执行的日常脚本",
            "values": [
                {
                    "des": "打开上传包的网站(pgyer)",
                    "key": "打开上传包的网站(pgyer)",
                    "command": "open https://www.pgyer.com/"
                }
            ]
        }
    ]
}